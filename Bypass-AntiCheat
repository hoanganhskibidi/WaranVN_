-- ================== 3. ENGINE TỰ ĐỘNG THÍCH ỨNG (ANTI-CHEAT TERMINATOR) ==================
local function containsBlacklist(str)
    if type(str) ~= "string" then return false end
    local lowerStr = string.lower(str)
    for _, keyword in ipairs(BLACKLIST_KEYWORDS) do
        if string.find(lowerStr, keyword) then return true end
    end
    return false
end

local function triggerNeutralize(info)
    neutralizedCount = neutralizedCount + 1
    addLog(info, Color3.fromRGB(255, 165, 0))
end

-- Khởi tạo các tầng bảo vệ dựa trên sức mạnh của Executor
local engineMode = "Reactive Mode (No-Hook Fallback)"

if hookmetamethod then
    engineMode = "Metatable Hook Mode (Advanced)"
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if bypassActive and (method == "FireServer" or method == "InvokeServer") then
            if containsBlacklist(self.Name) then
                triggerNeutralize("Blocked Namecall: " .. self.Name)
                return nil
            end
            for _, arg in ipairs({...}) do
                if type(arg) == "string" and containsBlacklist(arg) then
                    triggerNeutralize("Blocked Payload in: " .. self.Name)
                    return nil
                end
            end
        end
        return oldNamecall(self, ...)
    end)
elseif hookfunction then
    engineMode = "Function Hook Mode (Medium)"
    local oldFireServer
    oldFireServer = hookfunction(Instance.new("RemoteEvent").FireServer, function(self, ...)
        if bypassActive and containsBlacklist(self.Name) then
            triggerNeutralize("Hooked & Blocked: " .. self.Name)
            return nil
        end
        return oldFireServer(self, ...)
    end)
else
    engineMode = "Reactive Ghost Mode (Safe Fallback)"
end

addLog("Engine: " .. engineMode, Color3.fromRGB(100, 200, 255))

-- ================== 4. PHƯƠNG PHÁP ĐÁNH CHẶN CHỦ ĐỘNG (DÀNH CHO EXECUTOR YẾU) ==================
-- Cơ chế này phá hủy hoặc đổi tên Remote độc hại ngay khi chúng xuất hiện, khiến script game bị lỗi không gọi được!
local function handleNewObject(obj)
    if not bypassActive then return end

    -- Phá hủy script anti-cheat chạy ngầm
    if obj:IsA("LocalScript") and containsBlacklist(obj.Name) then
        pcall(function()
            obj.Disabled = true
            obj:Destroy()
            triggerNeutralize("Terminated Script: " .. obj.Name)
        end)
    end

    -- Đánh chặn và phá hỏng các cấu trúc Remote dò xét dữ liệu
    if (obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction")) then
        if containsBlacklist(obj.Name) then
            pcall(function()
                local oldName = obj.Name
                obj.Name = "N3utr0n_Safe_" .. math.random(1000, 9999) -- Đổi tên làm lệch hướng script check
                triggerNeutralize("Scrambled Remote: " .. oldName)
            end)
        end
    end

    -- Xóa các GUI phát hiện bất thường mà game tự chèn vào
    if (obj:IsA("ScreenGui") or obj:IsA("Frame")) and not obj:IsDescendantOf(gui) then
        if containsBlacklist(obj.Name) then
            pcall(function()
                obj:Destroy()
                triggerNeutralize("Wiped AC GUI: " .. obj.Name)
            end)
        end
    end
end

-- Theo dõi liên tục các vùng nhạy cảm bằng Event-Driven (Không gây tốn tài nguyên máy)
connections["ReplicatedMonitor"] = game:GetService("ReplicatedStorage").DescendantAdded:Connect(handleNewObject)
connections["GuiMonitor"] = LocalPlayer:WaitForChild("PlayerGui").DescendantAdded:Connect(handleNewObject)

local function cleanCurrentEnvironment()
    addLog("Scanning environment...", Color3.fromRGB(150, 150, 150))
    for _, obj in ipairs(game:GetService("ReplicatedStorage"):GetDescendants()) do handleNewObject(obj) end
    for _, obj in ipairs(LocalPlayer.PlayerGui:GetDescendants()) do handleNewObject(obj) end
    if LocalPlayer.Character then
        for _, obj in ipairs(LocalPlayer.Character:GetDescendants()) do handleNewObject(obj) end
    end
    addLog("Scan complete!", Color3.fromRGB(0, 255, 100))
end

